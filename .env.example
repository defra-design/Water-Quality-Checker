# Met Office Weather DataHub API keys
# Register at https://datahub.metoffice.gov.uk/

# Site-Specific Global Spot — rainfall totals (24h / 48h / 72h)
MET_OFFICE_GLOBAL_SPOT_API_KEY=

# Land Observations — nearest UK weather station (optional fallback)
MET_OFFICE_LAND_OBS_API_KEY=

# Legacy fallback if you use a single key for both APIs
# MET_OFFICE_API_KEY=

# Ordnance Survey Maps API — basemap tiles on /map
# Register at https://osdatahub.os.uk/
# Add OS Maps API to your API project, then copy the Project API Key
OS_MAPS_API_KEY=

# Optional: Road_3857, Outdoor_3857 (default), or Light_3857
# OS_MAPS_LAYER=Outdoor_3857
